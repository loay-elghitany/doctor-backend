# Database Configuration
# MongoDB connection string (use MongoDB Atlas for production)
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string

# Or use DB_URI as an alternative
# DB_URI=your_mongodb_connection_string

# JWT Secret (required)
# Generate a strong random string for production
# Example: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_here

# Environment
# Set to 'production' for production deployments
NODE_ENV=development

# Debug Mode
# Set to 'false' in production
DEBUG=true

# Admin Configuration (required)
# Generate using: echo -n "your_secret" | sha256sum
ADMIN_SECRET_TOKEN=your_admin_secret_token_here

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password

# CORS Configuration (required for production)
# Comma-separated list of allowed origins
# Example: https://clinic.vercel.app,https://clinic-ten.vercel.app,https://myclinic.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Main Domain (for tenant routing)
# The frontend domain without subdomain
# Example: clinic.vercel.app or myclinic.com
MAIN_DOMAIN=localhost:5173

# Port (required for production)
# Optional for development (defaults to 5000)
# PORT=5000

# WhatsApp Notifications (optional)
WHATSAPP_NOTIFICATIONS_ENABLED=false
WHATSAPP_PROVIDER=TWILIO
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary (optional - for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret